{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/DymaticMeta.js": {
      "includeFiles": "data/database.json"
    }
  },
  "headers": [
    {
      "source": "/archive/(.*).(litematic|webp|png|jpg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/Extra-Function(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/archive",
      "has": [
        {
          "type": "query",
          "key": "sub-(.*)"
        }
      ],
      "destination": "/api/DymaticRender"
    }
  ]
}